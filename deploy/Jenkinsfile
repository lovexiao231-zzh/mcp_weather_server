// Jenkinsfile for MCP Weather Server CI/CD
// 触发 GitHub webhook 后自动构建和部署

pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'lovexiao2311/mcp_weather_server'
        DEPLOY_HOST = '114.215.178.73'
        DEPLOY_USER = 'root'
        DEPLOY_DIR = '/opt/mcp-weather-server'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.APP_VERSION = sh(
                        script: "grep -oP '(?<=version = \").*(?=\")' pyproject.toml",
                        returnStdout: true
                    ).trim()
                    echo "应用版本：${env.APP_VERSION}"
                }
            }
        }

        stage('Docker Version Check') {
            steps {
                sh 'docker --version'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    echo "=== 构建 Docker 镜像 ==="
                    docker build -f Dockerfile.streamable-http -t ${DOCKER_IMAGE}:${APP_VERSION} .
                    docker build -f Dockerfile.streamable-http -t ${DOCKER_IMAGE}:latest .
                '''
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credential',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                        docker push ${DOCKER_IMAGE}:${APP_VERSION}
                        docker push ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('Deploy to Aliyun') {
            steps {
                withCredentials([file(
                    credentialsId: 'aliyun-ssh-key',
                    variable: 'SSH_KEY'
                )]) {
                    sh '''
                        # 创建远程部署目录
                        ssh -o StrictHostKeyChecking=no -i $SSH_KEY $DEPLOY_USER@$DEPLOY_HOST "mkdir -p $DEPLOY_DIR"

                        # 复制 docker-compose.yml 和部署脚本
                        scp -o StrictHostKeyChecking=no -i $SSH_KEY deploy/docker-compose.yml $DEPLOY_USER@$DEPLOY_HOST:$DEPLOY_DIR/
                        scp -o StrictHostKeyChecking=no -i $SSH_KEY deploy/deploy.sh $DEPLOY_USER@$DEPLOY_HOST:$DEPLOY_DIR/

                        # 执行远程部署
                        ssh -o StrictHostKeyChecking=no -i $SSH_KEY $DEPLOY_USER@$DEPLOY_HOST "export VERSION=$APP_VERSION && cd $DEPLOY_DIR && bash deploy.sh"
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                retry(3) {
                    timeout(time: 1, unit: 'MINUTES') {
                        waitForServer url: "http://114.215.178.73:8085/mcp", timeout: 60
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f'
            cleanWs()
        }
        success {
            echo '部署成功！'
        }
        failure {
            echo '部署失败，请检查日志'
        }
    }
}
